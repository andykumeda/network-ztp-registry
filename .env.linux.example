# ── Linux server Docker deployment .env ─────────────────────────────────────
#
# Copy this to /opt/ztp/.env on the Linux server (192.0.2.14).
# Fill in OPENGEAR_PASSWORD and DHCP_INTERFACE. All other values are correct.
#
# Run `ip link` on the Linux server to find DHCP_INTERFACE
# (the NIC connected to the switch management VLAN — e.g. ens3, eth0, bond0).

# ── OpenGear credentials (required) ─────────────────────────────────────────
OPENGEAR_HOST=192.0.2.253
OPENGEAR_USER=service
OPENGEAR_PASSWORD=changeme

# ── DHCP / network configuration ────────────────────────────────────────────
DHCP_INTERFACE=ens3
ZTP_SERVER_IP=192.0.2.14
ZTP_WEB_PORT=8080

DHCP_RANGE_START=192.0.2.100
DHCP_RANGE_END=192.0.2.200
DHCP_ROUTER=192.0.2.1
DHCP_DNS=8.8.8.8,8.8.4.4

# ── Host paths ───────────────────────────────────────────────────────────────
IOS_IMAGES_DIR=/var/www/ztp     # nginx-only dir — contains .bin IOS images
ANSIBLE_DIR=/opt/ztp/ansible
VAULT_PASS_FILE=/opt/ztp/ansible/.vault_pass.txt
