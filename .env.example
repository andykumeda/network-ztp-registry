# ── OpenGear credentials (required) ───────────────────────────────────────────
OPENGEAR_HOST=192.0.2.253
OPENGEAR_USER=service
OPENGEAR_PASSWORD=changeme

# ── DHCP / network configuration ──────────────────────────────────────────────
# Physical NIC on the switch management VLAN (run `ip link` to find the name).
# On the OpenGear CM8100, the management bridge is `br0` (not a physical NIC).
DHCP_INTERFACE=eth0

# IP of this host on the management VLAN — switches will download ztp.py
# from this address and call the lookup API on port 5000 at this address.
ZTP_SERVER_IP=192.0.2.14

# Port nginx listens on externally (must not conflict with the host's own services).
# On OpenGear hosts, port 80 is reserved for the management GUI; use 8080.
ZTP_WEB_PORT=8080

# DHCP lease pool (must be within the management subnet)
DHCP_RANGE_START=192.0.2.100
DHCP_RANGE_END=192.0.2.200

# Default gateway handed to switches via DHCP
DHCP_ROUTER=192.0.2.1

# DNS servers handed to switches via DHCP (comma-separated)
DHCP_DNS=8.8.8.8,8.8.4.4

# ── Host paths ─────────────────────────────────────────────────────────────────
# Directory containing IOS .bin images (served by nginx on ZTP_WEB_PORT)
# Must contain the image named in config.json ios_image_name.
IOS_IMAGES_DIR=/var/www/ztp

# Path where the ansible/ directory from the repo is deployed on this host.
# Linux server:    /opt/ztp/ansible
# OpenGear host:   /mnt/nvram/ztp/ansible
ANSIBLE_DIR=/opt/ztp/ansible

# Ansible vault password file. Placed manually on each host after first deploy.
# Never committed to git. Must match the path set in ANSIBLE_DIR.
# Linux server:    /opt/ztp/ansible/.vault_pass.txt
# OpenGear host:   /mnt/nvram/ztp/ansible/.vault_pass.txt
VAULT_PASS_FILE=/opt/ztp/ansible/.vault_pass.txt

# ── Optional tuning ────────────────────────────────────────────────────────────
# OPENGEAR_SCHEME=https
# OPENGEAR_PORT=
# OPENGEAR_API=/api/v2
# POLL_INTERVAL=30
# OPENGEAR_DEBUG=false
# LOOKUP_OVERRIDE_HOSTNAME=true

# ── ServiceNow push integration (optional) ────────────────────────────────────
# When enabled, server.py POSTs each created/updated device to the ServiceNow
# scripted REST endpoint. Best-effort — failures are logged, never block.
# SERVICENOW_ENABLED=true
# SERVICENOW_URL=https://example.service-now.com/api/unofv/mgn_staging/switches
# SERVICENOW_USER=api_service
# SERVICENOW_PASS=changeme
# SERVICENOW_TIMEOUT=10
# SERVICENOW_BATCH_WINDOW=10     # seconds to accumulate records before POSTing batch
