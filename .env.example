# Copy to .env for hardware-backed lab deployments.
# The included demo path does not require this file.

# Console server API credentials.
OPENGEAR_HOST=10.10.10.20
OPENGEAR_USER=ztp_api_user
OPENGEAR_PASSWORD=change-me
OPENGEAR_SCHEME=https
OPENGEAR_API=/api/v2

# ZTP lab network.
DHCP_INTERFACE=eth0
ZTP_SERVER_IP=10.10.10.10
ZTP_WEB_PORT=8080
DHCP_RANGE_START=10.10.10.100
DHCP_RANGE_END=10.10.10.200
DHCP_ROUTER=10.10.10.1
DHCP_DNS=1.1.1.1,8.8.8.8

# Host paths.
IOS_IMAGES_DIR=/opt/ztp/images
ANSIBLE_DIR=/opt/ztp/ansible
VAULT_PASS_FILE=/opt/ztp/ansible/.vault_pass.txt

# Optional ITSM/CMDB webhook sync. Disabled by default.
ITSM_ENABLED=false
ITSM_URL=https://itsm.example.com/api/network-ztp/devices
ITSM_USER=ztp-webhook-user
ITSM_PASS=change-me
ITSM_TIMEOUT=10
ITSM_BATCH_WINDOW=10
