# ── OpenGear CM8100 deployment .env ────────────────────────────────────────────
#
# Copy this to /mnt/nvram/ztp/.env on the OpenGear host (192.0.2.253).
# Fill in the actual password. All other values below are correct for this site.
#
# Key differences from a standard Linux host (.env.example):
#   DHCP_INTERFACE  — CM8100 uses a bridge (br0), not a physical NIC
#   ZTP_SERVER_IP   — the OpenGear's own management IP
#   ZTP_WEB_PORT    — port 80 is the OpenGear management GUI; use 8080
#   IOS_IMAGES_DIR  — writable NVRAM path replaces /var/www/ztp
#   ANSIBLE_DIR     — ansible/ from the repo, deployed to NVRAM by deploy.sh
#   VAULT_PASS_FILE — vault password, placed manually at this path after first deploy

# ── OpenGear credentials (required) ───────────────────────────────────────────
OPENGEAR_HOST=192.0.2.253
OPENGEAR_USER=service
OPENGEAR_PASSWORD=changeme

# ── DHCP / network configuration ──────────────────────────────────────────────
DHCP_INTERFACE=br0
ZTP_SERVER_IP=192.0.2.253
ZTP_WEB_PORT=8080

# DHCP lease pool
DHCP_RANGE_START=192.0.2.100
DHCP_RANGE_END=192.0.2.200

# Default gateway
DHCP_ROUTER=192.0.2.1

# DNS servers
DHCP_DNS=8.8.8.8,8.8.4.4

# ── Host paths (NVRAM — the only writable filesystem on CM8100) ───────────────
IOS_IMAGES_DIR=/mnt/nvram/ztp
ANSIBLE_DIR=/mnt/nvram/ztp/ansible
VAULT_PASS_FILE=/mnt/nvram/ztp/ansible/.vault_pass.txt

# ── ServiceNow push integration ───────────────────────────────────────────────
# Uncomment and set SERVICENOW_ENABLED=true AFTER the admin confirms payload
# structure. Credentials provided by the ServiceNow admin.
# SERVICENOW_ENABLED=true
# SERVICENOW_URL=https://example.service-now.com/api/unofv/mgn_staging/switches
# SERVICENOW_USER=api_service
# SERVICENOW_PASS=changeme
# SERVICENOW_TIMEOUT=10
# SERVICENOW_BATCH_WINDOW=10
